# ============================================================
# MediSoft C-OS — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to the repository.
# ============================================================

# ─── Core (REQUIRED) ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/medisoft_db?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/medisoft_db?sslmode=require
BETTER_AUTH_SECRET=your-random-secret-min-32-chars
BETTER_AUTH_URL=https://app.medisofthealth.com
NEXT_PUBLIC_APP_URL=https://app.medisofthealth.com

# ─── AI / LLM (REQUIRED for MediBot, transcription, analysis) ───
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# ─── Google Cloud Platform ─────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=me-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_GENAI_USE_VERTEXAI=false

# ─── Google Healthcare API (optional — for FHIR/DICOM/Consent) ───
GCP_HEALTHCARE_DATASET=
GCP_HEALTHCARE_LOCATION=
GCP_FHIR_STORE=
GCP_DICOM_STORE=
GCP_CONSENT_STORE=
USE_CLOUD_CONSENT_API=false

# ─── MedGemma / Vertex AI (optional — advanced medical AI) ───
ENABLE_MEDGEMMA=false
MEDGEMMA_ENABLED=false
MEDGEMMA_MODEL=
MEDGEMMA_VISION_MODEL=
USE_VERTEX_ENDPOINTS=false
VERTEX_HEAR_ENDPOINT=
VERTEX_MEDASR_ENDPOINT=
VERTEX_MEDGEMMA_ENDPOINT=
VERTEX_MEDSIGLIP_ENDPOINT=
VERTEX_PATH_FOUNDATION_ENDPOINT=
VERTEX_TXGEMMA_ENDPOINT=

# ─── Google Health Connect (optional — device integration) ───
GOOGLE_HEALTH_CONNECT_CLIENT_ID=
GOOGLE_HEALTH_CONNECT_CLIENT_SECRET=

# ─── MediSport Exercise Library (optional) ─────────────────
MUSCLEWIKI_API_KEY=
MUSCLEWIKI_BASE_URL=https://api.musclewiki.com
EXERCISEDB_BASE_URL=

# ─── Twilio (optional — SMS/WhatsApp notifications) ────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
