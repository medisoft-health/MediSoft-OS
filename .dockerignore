# ══════════════════════════════════════════════════════════════════
#  MediSoft C-OS — .dockerignore
# ══════════════════════════════════════════════════════════════════
#  كل ملف هنا يُستثنى من Docker build context.
#  هذا يقلل حجم الـ context ويسرّع البناء.
# ══════════════════════════════════════════════════════════════════

# ─── الاعتمادات (تُثبّت من جديد داخل Docker) ─────────────────────
node_modules
.pnp
.pnp.js

# ─── مخرجات البناء (تُبنى من جديد) ──────────────────────────────
.next
out
build
dist

# ─── Git ─────────────────────────────────────────────────────────
.git
.gitignore

# ─── متغيرات البيئة (أسرار — لا تدخل Docker أبداً) ──────────────
.env
.env.*
!.env.example

# ─── مفاتيح وأسرار ──────────────────────────────────────────────
*.pem
*.key
*.key.json
*-credentials.json
medisoft-chatbot-*.json

# ─── ملفات macOS ────────────────────────────────────────────────
.DS_Store
*.swp

# ─── ملفات IDE ──────────────────────────────────────────────────
.vscode
.idea
*.code-workspace

# ─── Docker files (لا نحتاجها داخل الـ image) ────────────────────
Dockerfile
docker-compose.yml
.dockerignore

# ─── CI/CD ───────────────────────────────────────────────────────
.github
cloudbuild.yaml

# ─── اختبارات (لا نحتاجها في الإنتاج) ───────────────────────────
coverage
*.test.ts
*.test.tsx
*.spec.ts
vitest.config.ts
src/test/
src/__tests__/
src/**/__tests__/

# ─── وثائق ──────────────────────────────────────────────────────
*.md
!README.md
LICENSE

# ─── Logs ────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── سكريبتات النشر ──────────────────────────────────────────────
scripts/

# ─── Vercel ──────────────────────────────────────────────────────
.vercel

# ─── TypeScript build info ───────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
